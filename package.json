{
  "name": "neurowiki",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:analyze": "ANALYZE=true vite build",
    "preview": "vite preview",
    "postbuild": "react-snap"
  },
  "dependencies": {
    "@google/genai": "^1.34.0",
    "lucide-react": "^0.562.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.11.0",
    "resend": "^6.8.0"
  },
  "devDependencies": {
    "@netlify/functions": "^5.1.2",
    "@tailwindcss/vite": "^4.1.18",
    "@types/node": "^22.14.0",
    "@vercel/node": "^5.6.4",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.23",
    "postcss": "^8.5.6",
    "react-snap": "^1.23.0",
    "rollup-plugin-visualizer": "^6.0.5",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  },
  "reactSnap": {
    "source": "dist",
    "crawl": false,
    "puppeteerArgs": [
      "--no-sandbox",
      "--disable-setuid-sandbox",
      "--disable-dev-shm-usage"
    ],
    "skipThirdPartyRequests": true,
    "renderAfterTime": 1500,
    "include": [
      "/",
      "/calculators",
      "/calculators/nihss",
      "/calculators/evt-pathway",
      "/calculators/late-window-ivt",
      "/calculators/elan-pathway",
      "/calculators/se-pathway",
      "/calculators/aspects-score",
      "/calculators/ich-score",
      "/calculators/abcd2-score",
      "/calculators/glasgow-coma-scale",
      "/calculators/has-bled-score",
      "/calculators/rope-score",
      "/calculators/heidelberg-bleeding-classification",
      "/calculators/boston-criteria-caa",
      "/guide",
      "/guide/iv-tpa",
      "/guide/stroke-basics",
      "/guide/thrombectomy",
      "/guide/ich-management",
      "/guide/status-epilepticus",
      "/guide/gbs",
      "/guide/myasthenia-gravis",
      "/trials",
      "/trials/dawn-trial",
      "/trials/defuse-3-trial",
      "/trials/wake-up-trial",
      "/trials/extend-trial",
      "/trials/elan-study",
      "/trials/original-trial",
      "/trials/select2-trial",
      "/trials/ninds-trial",
      "/trials/angel-aspect-trial"
    ]
  }
}
