{
  "name": "neurowiki",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:analyze": "ANALYZE=true vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "check:routes": "node scripts/validateRouteManifest.mjs",
    "check:claims": "tsx scripts/check-claims.ts",
    "check:chains": "tsx scripts/check-trial-chains.ts",
    "check:humanizer": "node scripts/check-humanizer.mjs",
    "fix:em-dashes": "node scripts/fix-em-dashes.mjs --write",
    "seo:auth-login": "node --env-file=.env.local scripts/seo/auth-login.mjs",
    "seo:fetch-ga4": "node --env-file=.env.local scripts/seo/fetch-ga4.mjs",
    "seo:fetch-gsc": "node --env-file=.env.local scripts/seo/fetch-gsc.mjs",
    "seo:report": "node --env-file=.env.local scripts/seo/generate-weekly-report.mjs",
    "seo:weekly": "npm run seo:fetch-ga4 && npm run seo:fetch-gsc && npm run seo:report",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepare": "husky"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.106.0",
    "html5-qrcode": "^2.3.8",
    "lucide-react": "^0.562.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.11.0",
    "recharts": "^3.8.0",
    "remark-gfm": "^4.0.1",
    "resend": "^6.8.0"
  },
  "devDependencies": {
    "@google-analytics/data": "^6.0.0",
    "@tailwindcss/vite": "^4.1.18",
    "@types/node": "^22.14.0",
    "@types/qrcode": "^1.5.6",
    "@vercel/node": "^5.6.4",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitest/coverage-v8": "^4.1.6",
    "autoprefixer": "^10.4.23",
    "google-auth-library": "^10.6.2",
    "googleapis": "^171.4.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.6",
    "react-snap": "^1.23.0",
    "rollup-plugin-visualizer": "^6.0.5",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.6"
  },
  "reactSnap": {
    "source": "dist",
    "crawl": false,
    "puppeteerArgs": [
      "--no-sandbox",
      "--disable-setuid-sandbox",
      "--disable-dev-shm-usage"
    ],
    "skipThirdPartyRequests": true,
    "renderAfterTime": 1500,
    "inlineCss": false,
    "minifyHtml": {
      "collapseWhitespace": false,
      "removeComments": false
    },
    "viewport": {
      "width": 1280,
      "height": 800
    },
    "include": [
      "/",
      "/calculators",
      "/pathways",
      "/guide",
      "/trials",
      "/calculators/nihss",
      "/calculators/aspects-score",
      "/calculators/ich-score",
      "/calculators/glasgow-coma-scale",
      "/calculators/abcd2-score",
      "/calculators/has-bled-score"
    ]
  }
}
