{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/favicon.png",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    },
    {
      "source": "/og-image.png",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    }
  ],
  "redirects": [
    { "source": "/calculators/stroke-code", "destination": "/pathways/stroke-code", "permanent": true },
    { "source": "/calculators/evt-pathway", "destination": "/pathways/evt", "permanent": true },
    { "source": "/calculators/evt", "destination": "/pathways/evt", "permanent": true },
    { "source": "/pathways/evt-pathway", "destination": "/pathways/evt", "permanent": true },
    { "source": "/calculators/late-window-ivt", "destination": "/pathways/late-window-ivt", "permanent": true },
    { "source": "/calculators/elan-pathway", "destination": "/pathways/elan-pathway", "permanent": true },
    { "source": "/calculators/se-pathway", "destination": "/pathways/se-pathway", "permanent": true },
    { "source": "/calculators/migraine-pathway", "destination": "/pathways/migraine-pathway", "permanent": true },
    { "source": "/calculators/gca-pathway", "destination": "/pathways/gca-pathway", "permanent": true }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
