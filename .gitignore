# Google Search Console / Cloud credentials — defensive root-level guard.
# Canonical location is docs/seo-data/ (with its own .gitignore); these
# patterns catch anything that accidentally lands at the repo root.
client_secrets.json
client_secret*.json
oauth_client*.json
service-account*.json
*-credentials.json
*-service-account.json
token.json
.oauth-token.json
.gsc_*

# Android TWA local signing material and build outputs
.android-secrets/
*.jks
*.keystore
*.p12
android/*.apk
android/*.aab
android/*.idsig
android/.gradle/
android/**/build/
android/local.properties
android/.idea/
android/*.iml
